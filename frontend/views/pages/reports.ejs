<%- include('../partials/header') %>
<%- include('../partials/sidebar', { activePage: 'reports', user: user }) %>

<div id="reportSection" class="page-section">
    <div class="header">
        <h2>📈 Reports</h2>
    </div>
    <div class="card">
        <div class="report-actions" style="display:flex; gap:12px; margin-bottom:16px;">
            <a href="/download" class="btn-download" style="padding:10px; text-decoration:none; display:inline-block; border-radius:6px;">⬇ Download Excel</a>
            <form action="/reports/refresh" method="POST" style="margin:0;">
                <button type="submit" class="btn-primary">🔄 Refresh Report Data</button>
            </form>
        </div>

        <div id="reportSummary" class="report-summary-row">
            <div><strong>Total entries:</strong> <%= totals.total_entries || totals.total_shipments || 0 %></div>
            <div><strong>Total kgs:</strong> <%= totals.total_kgs || totals.total_quantity || 0 %></div>
        </div>

        <table class="user-table" style="margin-top:16px;">
            <thead>
                <tr>
                    <th>UOM</th>
                    <th>Material Grade</th>
                    <th>Total kgs</th>
                </tr>
            </thead>
            <tbody>
                <% if(breakdown && breakdown.length > 0) { %>
                    <% breakdown.forEach(function(row) { %>
                        <tr>
                            <td><%= row.uom || 'N/A' %></td>
                            <td><%= row.material_grade || 'N/A' %></td>
                            <td><%= row.total_kgs || 0 %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="3" style="text-align:center; color:#64748b;">No breakdown data</td></tr>
                <% } %>
            </tbody>
        </table>

        <div class="header" style="margin-top:20px;">
            <h2>📦 All entries</h2>
        </div>

        <table class="user-table">
            <thead>
                <tr>
                    <th>Rm Dimensions</th>
                    <th>Material Grade</th>
                    <th>Material</th>
                    <th>UOM</th>
                    <th>Kgs</th>
                    <th>Date</th>
                    <th>QR</th>
                </tr>
            </thead>
            <tbody>
                <% if(shipments && shipments.length > 0) { %>
                    <% shipments.forEach(function(row, index) { %>
                        <tr>
                            <td><%= row.raw_material_dimensions || 'N/A' %></td>
                            <td><%= row.material_grade || 'N/A' %></td>
                            <td><%= row.material_type || 'N/A' %></td>
                            <td><%= row.uom || '' %></td>
                            <td><%= row.kgs || 0 %></td>
                            <td><%= new Date(row.shipment_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                            <td style="text-align:center;">
                                <% if(index === 0) { %>
                                    <button class="btn-download" type="button" onclick="document.getElementById('qrModal').style.display='flex'">QR</button>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="7" style="text-align:center; color:#64748b;">No entries found</td></tr>
                <% } %>
            </tbody>
        </table>
        
        <!-- Pagination logic (simplified) -->
        <div class="shipment-pagination">
            <% if (page > 0) { %>
                <a href="/reports?page=<%= page - 1 %>" class="btn-primary" style="text-decoration:none; padding:4px 10px;">&lt; Previous</a>
            <% } %>
            <span style="margin: 0 10px;">Showing page <%= page + 1 %></span>
            <% if ((page + 1) * 10 < totals.total_entries) { %>
                <a href="/reports?page=<%= page + 1 %>" class="btn-primary" style="text-decoration:none; padding:4px 10px;">Next &gt;</a>
            <% } %>
        </div>
    </div>
</div>

<% if(shipments && shipments.length > 0) { %>
    <!-- QR Modal just for the first shipment to match prior frontend functionality -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <div id="qrModal" class="qr-modal" style="display:none;">
        <div class="qr-modal-content">
            <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                <h3 style="margin:0;">Raw material QR</h3>
                <button id="qrModalClose" class="btn-primary" type="button" style="padding:6px 10px;">Close</button>
            </div>
            <div style="display:flex; gap:15px; align-items:center;">
                <div id="qrModalContainer" style="width:220px;height:220px;"></div>
                <pre style="background:#f8fafc; border:1px solid #e2e8f0; padding:10px; border-radius:8px;"><%= `Raw material details\nID: ${shipments[0].id}\nDimensions: ${shipments[0].raw_material_dimensions}\nMaterial Grade: ${shipments[0].material_grade}\nMaterial: ${shipments[0].material_type}\nUOM: ${shipments[0].uom}\nKgs: ${shipments[0].kgs}` %></pre>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const qrContainer = document.getElementById("qrModalContainer");
            if (qrContainer && typeof QRCode !== 'undefined') {
                new QRCode(qrContainer, {
                    text: `<%= `Raw material details\nID: ${shipments[0].id}\nDimensions: ${shipments[0].raw_material_dimensions}\nMaterial Grade: ${shipments[0].material_grade}\nMaterial: ${shipments[0].material_type}\nUOM: ${shipments[0].uom}\nKgs: ${shipments[0].kgs}` %>`,
                    width: 220,
                    height: 220
                });
            }
        });
    </script>
<% } %>

<%- include('../partials/footer') %>
