<%- include('../partials/header') %>
<%- include('../partials/sidebar', { activePage: 'auth', user: null }) %>

<div id="authSection" class="card auth-panel" style="margin-top: 40px;">
    <h3>🔐 Sign In / Sign Up</h3>
    <% if (typeof error !== 'undefined' && error) { %>
        <p style="color:#dc2626; margin-bottom:10px;"><%= error %></p>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <p style="color:#16a34a; margin-bottom:10px;"><%= success %></p>
    <% } %>

    <div class="auth-tabs" style="display: flex; gap: 10px; margin-bottom: 12px; flex-wrap: wrap;">
        <button id="signInTab" class="btn-primary" type="button">Sign In</button>
        <button id="signUpTab" class="btn-primary" type="button">Sign Up</button>
    </div>

    <form id="signInForm" action="/signin" method="POST" style="display:block;">
        <input type="email" name="email" placeholder="Email" required>
        <input type="password" name="password" placeholder="Password" required>
        <button class="btn-primary" type="submit">Sign In</button>
    </form>

    <form id="signUpForm" action="/signup" method="POST" style="display:none; margin-top:10px;">
        <input type="text" name="name" placeholder="Full Name" required>
        <input type="email" name="email" placeholder="Email" required>
        <input type="password" name="password" placeholder="Password" required>
        <input type="text" name="role" placeholder="Designation (e.g., Manager, Analyst)" required>
        <button class="btn-primary" type="submit">Sign Up</button>
    </form>
</div>

<%- include('../partials/footer') %>
