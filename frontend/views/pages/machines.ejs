<%- include('../partials/header') %>
<%- include('../partials/sidebar', { activePage: 'machines', user: user }) %>

<div id="machinesSection" class="page-section">
    <div class="header">
        <h2>⚙️ Machines</h2>
    </div>
    <div class="card machine-panel">
        <label for="machineTypeSelect" style="display:block; font-weight:600; color:#334155; margin-bottom:8px;">Machine type</label>
        <select id="machineTypeSelect" onchange="window.location.href='/machines?selected=' + this.value">
            <option value="" <%= !selected ? 'selected' : '' %> disabled>Select machine…</option>
            <option value="CMC" <%= selected === 'CMC' ? 'selected' : '' %>>CMC — CNC machining center</option>
            <option value="VMC" <%= selected === 'VMC' ? 'selected' : '' %>>VMC — Vertical machining center</option>
            <option value="TMC" <%= selected === 'TMC' ? 'selected' : '' %>>TMC — Turn-mill / turning center</option>
        </select>
        
        <% if (selected) { %>
            <div id="machineDetail" class="machine-detail-panel" style="margin-top: 1.25rem; padding: 1rem 1.15rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; color: #475569;">
                <% if (selected === 'CMC') { %>
                    <strong>CMC</strong> — CNC machining center for milling, drilling, and related operations.
                <% } else if (selected === 'VMC') { %>
                    <strong>VMC</strong> — Vertical machining center; vertical spindle for flat workpieces, pockets, and 3-axis programs.
                <% } else if (selected === 'TMC') { %>
                    <strong>TMC</strong> — Turn-mill / turning center with live tooling or mill-turn for shafts and rotational parts.
                <% } %>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
